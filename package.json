{
  "name": "snatch",
  "version": "2.0.0",
  "description": "Download videos from YouTube, Twitter, Instagram and 1000+ sites",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.snatch.app",
    "productName": "Snatch",
    "directories": { "output": "dist" },
    "win": { "target": "nsis" },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["ru_RU", "en_US"],
      "language": "1049"
    },
    "files": ["main.js", "preload.js", "index.html", "package.json"],
    "extraResources": [{ "from": "bin/", "to": "bin/", "filter": ["**/*"] }]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
